// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  userRoles UserRole[]
}

model Role {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  color       String          @default("#e94e1b")
  userRoles   UserRole[]
  permissions AppPermission[]
}

enum AppPermission {
  MANAGE_USERS
  MANAGE_ROLES
  REVIEW_ANNALES
}

model UserRole {
  id     Int    @id @default(autoincrement())
  userId String
  roleId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Major {
  id   Int    @id @default(autoincrement())
  name String @unique // ex: Informatique, Mathématiques

  parcours Parcours[]
}

model Level {
  id      Int      @id @default(autoincrement())
  name    String   @unique // ex: L1, L2, L3, M1, M2
  courses Course[]
}

model Parcours {
  id      Int      @id @default(autoincrement())
  name    String   @unique // ex: "Portail IEEEA", "Informatique", "Master SSI"
  majors  Major[]
  courses Course[]
}

model Course {
  id        Int        @id @default(autoincrement())
  name      String
  semestre  Int
  parcours  Parcours[]
  level     Level      @relation(fields: [levelId], references: [id])
  levelId   Int
  examTypes ExamType[]
  pastExams PastExam[]
}

model ExamType {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  course   Course[]
  pastExam PastExam[]
}

model PastExam {
  id         Int      @id @default(autoincrement())
  path       String   @unique
  year       Int
  course     Course   @relation(fields: [courseId], references: [id])
  courseId   Int
  examtype   ExamType @relation(fields: [examTypeId], references: [id])
  examTypeId Int
  annexe     Annexe[]
}

model Annexe {
  id         Int      @id @default(autoincrement())
  name       String
  type       Type
  isVerifed  Boolean
  path       String?
  url        String?
  pastExam   PastExam @relation(fields: [pastExamId], references: [id])
  pastExamId Int
}

enum Type {
  FILE
  URL
}

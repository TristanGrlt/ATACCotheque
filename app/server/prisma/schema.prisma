// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Major {
  id       Int        @id @default(autoincrement())
  name     String     @unique // ex: Informatique, Mathématiques
  
  parcours Parcours[] 
}

model Level {
  id       Int        @id @default(autoincrement())
  name     String     @unique // ex: L1, L2, L3, M1, M2
  courses  Course[]   
}

model Parcours {
  id       Int        @id @default(autoincrement())
  name     String     @unique// ex: "Portail IEEEA", "Informatique", "Master SSI"
  majors   Major[]
  courses  Course[]
}

model Course {
  id         Int        @id @default(autoincrement())
  name       String 
  semestre   Int     
  parcours   Parcours[]
  level      Level      @relation(fields: [levelId], references: [id])
  levelId    Int
  examTypes  ExamType[]
  pastExams  PastExam[]
}
model ExamType{
	id       Int       @id @default(autoincrement())
  name String @unique
  course Course[]
  pastExam PastExam[]
}

model PastExam{
	id       Int       @id @default(autoincrement())
    path String @unique
    year Int 
    course Course  @relation(fields: [courseId], references: [id])
    courseId Int 
    examtype ExamType  @relation(fields: [examTypeId], references: [id])
    examTypeId  Int
    isVerified Boolean @default(false)
    annexe Annexe[]
}

model Annexe{
  	id       Int       @id @default(autoincrement())
    name String 
    type Type
    path String?
    url String? 
    pastExam PastExam  @relation(fields: [pastExamId], references: [id])
    pastExamId Int
    isVerified Boolean @default(false)



}


enum Type {
	FILE
	URL
}